# Template de env vars pro deploy em producao (Dokploy)
#
# Como usar:
# 1. NAO commitar o .env real com secrets.
# 2. No Dokploy, criar cada variavel abaixo na UI do app com os valores reais.
# 3. Gerar secrets fortes antes de subir (comandos abaixo).
#
# Arquivo de referencia apenas. Nao e carregado automaticamente, serve de checklist.

# ============================================================================
# URL publica da aplicacao
# ============================================================================
# Usado pelo Docmost pra gerar URLs absolutas em links de share, emails, etc.
# DEVE bater com o dominio configurado no Traefik (ver docker-compose.prod.yml).
APP_URL=https://docs.persua.com.br

# ============================================================================
# Chave secreta da aplicacao (sessions, tokens internos)
# ============================================================================
# Gerar com: openssl rand -hex 32
# IMPORTANTE: trocar invalida todas as sessoes existentes. Em deploy novo zero
# problema. Em deploy existente, usuarios precisam relogar.
APP_SECRET=<gerar com openssl rand -hex 32>

# ============================================================================
# Senha do Postgres
# ============================================================================
# Gerar com: openssl rand -base64 24
# Usada tanto pela db quanto pelo docmost via DATABASE_URL construida no compose.
POSTGRES_PASSWORD=<gerar com openssl rand -base64 24>
