# Template de env vars pro deploy em producao (Dokploy)
#
# Como usar:
# 1. NAO commitar o .env real com secrets.
# 2. No Dokploy UI, ir em Environment do app docs-persua.
# 3. Colar cada variavel abaixo com os valores reais.
# 4. Save + redeploy.
#
# Arquivo de referencia apenas, nao e carregado automaticamente.
# Serve como checklist e fonte da formatacao correta das URLs.

# ============================================================================
# URL publica da aplicacao
# ============================================================================
# Usado pelo Docmost pra gerar URLs absolutas em links de share, emails, etc.
# DEVE bater com o dominio configurado no Traefik / Dokploy.
APP_URL=https://docs.persua.com.br

# ============================================================================
# Chave secreta da aplicacao (sessions, tokens internos)
# ============================================================================
# Gerar com: openssl rand -hex 32
APP_SECRET=<gerar com openssl rand -hex 32>

# ============================================================================
# Postgres (compartilhado, ja rodando no Swarm)
# ============================================================================
# Servico: postgres_postgres (rede network_swarm_public)
# Antes do deploy, criar database + user dedicado pro docmost:
#   - Conectar como superuser no postgres_postgres
#   - Rodar o script sql/setup-postgres.sql (esta no repo)
#   - Anotar a senha gerada pra colar abaixo
DATABASE_URL=postgresql://docmost:<senha-gerada-no-setup>@postgres_postgres:5432/docmost?schema=public

# ============================================================================
# Redis (compartilhado, ja rodando no Swarm)
# ============================================================================
# Servico: redis_redis (rede network_swarm_public)
# DB 4 reservada pro docmost (outros apps usam 0-3)
# Pegar a senha real do Redis no Dokploy/Swarm e colar abaixo
REDIS_URL=redis://default:<senha-do-redis-swarm>@redis_redis:6379/4
